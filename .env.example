DISCORD_TOKEN=
DISCORD_CLIENT_ID=
COMMAND_PREFIX=>>
DB_PATH=data/bot.db

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# EventSub webhook transport — required to track streamers other than
# yourself (websocket transport only works for broadcasters who've
# authorized this app). generate a random secret string for this, twitch
# uses it to sign delivery payloads so we can verify they're genuine.
TWITCH_WEBHOOK_SECRET=
# public https url twitch will POST event deliveries to. must be reachable
# from the internet and end in /webhook/twitch — e.g.
# https://flowerco.aichi.me:8082/webhook/twitch
TWITCH_WEBHOOK_CALLBACK_URL=
TWITCH_WEBHOOK_ENABLED=true
TWITCH_WEBHOOK_HOST=0.0.0.0
TWITCH_WEBHOOK_PORT=8082

DASHBOARD_ENABLED=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8081
# origin allowed to call the dashboard API. set this to your static frontend's
# url (e.g. https://you.github.io) once you're not serving the frontend from
# this same process. "*" is fine for local testing.
DASHBOARD_ORIGIN=*
